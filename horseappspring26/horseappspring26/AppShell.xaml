<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="horseappspring26.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:horseappspring26.Views"
    Title="Horse App Demo"
    FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="login" />

    <ShellContent
        Title="Horses"
        ContentTemplate="{DataTemplate views:HorseListPage}"
        Route="horses" />

</Shell>
