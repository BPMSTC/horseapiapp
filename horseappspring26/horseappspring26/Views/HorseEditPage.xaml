<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="horseappspring26.Views.HorseEditPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label Text="{Binding PageTitle}"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Name" />
            <Entry Text="{Binding Name}" />

            <Label Text="Registration Number" />
            <Entry Text="{Binding RegistrationNumber}" />

            <Label Text="Date of Birth" />
            <DatePicker Date="{Binding DateOfBirth}" />

            <Label Text="Gender" />
            <Picker ItemsSource="{Binding GenderOptions}"
                    SelectedItem="{Binding Gender}" />

            <Label Text="Color" />
            <Entry Text="{Binding Color}" />

            <Label Text="Sire" />
            <Entry Text="{Binding Sire}" />

            <Label Text="Dam" />
            <Entry Text="{Binding Dam}" />

            <Label Text="Breeder" />
            <Entry Text="{Binding BreederName}" />

            <Label Text="Picture Url" />
            <Entry Text="{Binding PictureUrl}" />

            <Label Text="Total Races" />
            <Entry Text="{Binding TotalRacesRun}" Keyboard="Numeric" />

            <Label Text="Wins" />
            <Entry Text="{Binding Wins}" Keyboard="Numeric" />

            <Label Text="Places" />
            <Entry Text="{Binding Places}" Keyboard="Numeric" />

            <Label Text="Shows" />
            <Entry Text="{Binding Shows}" Keyboard="Numeric" />

            <Label Text="Career Earnings" />
            <Entry Text="{Binding CareerEarnings}" Keyboard="Numeric" />

            <Label Text="Current Owner" />
            <Entry Text="{Binding CurrentOwner}" />

            <Label Text="Trainer" />
            <Entry Text="{Binding Trainer}" />

            <HorizontalStackLayout Spacing="10" Margin="0,12,0,0">
                <Button Text="Save"
                        Command="{Binding SaveCommand}" />

                <Button Text="Cancel"
                        Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
